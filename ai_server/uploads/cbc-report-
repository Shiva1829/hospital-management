    pannelFormat.style.opacity = "1";

    const showFormat = () => {
      head.classList.add("bg-slate-100");
      format.style.opacity = "1";
      format.style.pointerEvents = "auto";
      svg.classList.add("animate-svg");
    };

    const hideFormat = () => {
      head.classList.remove("bg-slate-100");
      format.style.opacity = "0";
      format.style.pointerEvents = "none";
      pannelFormat.style.opacity = "1";
      svg.classList.remove("animate-svg");
    };

    const addRotation = () => {
      svg.classList.add("animate-svg");
    };

    const removeRotation = () => {
      svg.classList.remove("animate-svg");
    };

    const isHoveringElement = elem => {
      return elem && elem.matches(":hover");
    };

    const handleHoverCheck = () => {
      clearTimeout(hoverTimeout);
