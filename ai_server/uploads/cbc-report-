<script>
(function() {
  const openBtn = document.getElementById('open-google-meet-modal');
  const closeBtn = document.getElementById('close-google-meet-modal');
  const modal = document.getElementById('google-meet-modal');

  const shareScreenModal = document.getElementById('share-meet-screen-modal');
  const closeShareScreenBtn = document.getElementById('close-share-meet-screen-modal');
  const proceedToMeetLink = document.getElementById('proceed-to-meet');
  const iframe = document.getElementById('share-screen-iframe');

  const autoplayUrl = "https://www.youtube.com/embed/FtI059_yA40?si=iDEZJhkhv0aKtH3f&autoplay=1"
  const url = "https://www.youtube.com/embed/FtI059_yA40?si=iDEZJhkhv0aKtH3f"

  function openModal() {
    modal.classList.add('is-active');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.remove('is-active');
    document.body.style.overflow = 'auto';
  }

  function openShareScreenModal() {
    shareScreenModal.classList.add('is-active');
    document.body.style.overflow = 'hidden';
    iframe.src = autoplayUrl
  }

  function closeShareScreenModal() {
    shareScreenModal.classList.remove('is-active');
    document.body.style.overflow = 'auto';
    iframe.src = ""
  }

  openBtn.addEventListener('click', openModal);
  closeBtn.addEventListener('click', closeModal);

  closeShareScreenBtn.addEventListener('click', closeShareScreenModal);
  proceedToMeetLink.addEventListener('click', ()=>{
    iframe.src = url
  })

  const joinMeetingLinks = document.querySelectorAll('.join-meet-btn');

  joinMeetingLinks.forEach(link => {
    link.addEventListener('click', function(e) {
      e.preventDefault();

      const href = this.getAttribute('data-href');
      proceedToMeetLink.setAttribute('href', href);

      openShareScreenModal();
    });
  });

  shareScreenModal.addEventListener("click", (e) => {
    if (e.target === shareScreenModal) {
      closeShareScreenModal();
    }
  });
})();

</script>



